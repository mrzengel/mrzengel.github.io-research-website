@article{naharDatasetDensityFunctional2024,
  title = {Dataset on Density Functional Theory Investigation of Ternary {{Heusler}} Alloys},
  author = {Nahar, Ridwan and Law, Ka Ming and Roden, Thomas and Zengel, Michael and Lewis, Justin and Budhathoki, Sujan and Nold, Riley and Avlani, Harshil and Akintunde, Babajide and Derksen, Naomi and Hauser, Adam J.},
  date = {2024-02},
  year = {2024},
  month = feb,
  journaltitle = {Data in Brief},
  shortjournal = {Data in Brief},
  volume = {52},
  pages = {109971},
  issn = {23523409},
  doi = {10.1016/j.dib.2023.109971},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S2352340923010028},
  urldate = {2026-06-19},
  langid = {english},
  abstract = {This paper contains data and results from Density Functional Theory (DFT) investigation of 423 distinct X2YZ ternary full Heusler alloys, where X and Y represent elements from the D-block of the periodic table and Z signifies element from main group. The study encompasses both “regular” and “inverse” Heusler phases of these alloys for a total of 846 potential materials. For each specific alloy and each phase, a range of information is provided including total energy, formation energy, lattice constant, total and site-specific magnetic moments, spin polarization as well as total and projected density of electronic states. The aim of creating this dataset is to provide fundamental theoretical insights into ternary X2YZ Heusler alloys for further theoretical and experimental analysis.}
}

@article{zengelAtomicOrderingElectronic2025,
  title = {Atomic Ordering and Electronic Structure of {{A2YSn Heusler}} Alloys: {{A}} First-Principles Study},
  shorttitle = {Atomic Ordering and Electronic Structure of {{A2YSn Heusler}} Alloys},
  author = {Zengel, Michael and Nold, Riley and Roden, Thomas and Law, Ka Ming and Nahar, Ridwan and Lewis, Justin and Hauser, Adam J.},
  date = {2025-04},
  year = {2025},
  month = apr,
  journaltitle = {Journal of Alloys and Compounds},
  shortjournal = {Journal of Alloys and Compounds},
  volume = {1021},
  pages = {179270},
  issn = {09258388},
  doi = {10.1016/j.jallcom.2025.179270},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S092583882500828X},
  urldate = {2026-06-19},
  langid = {english},
  abstract = {First-principles calculations are performed for the full Heusler L21 and inverse Heusler XA phases of the A2YSn series, with A spanning the 3d block of the transition metals (A = Sc, Ti, V, Cr, Mn, Fe, Co, Ni, Cu, Zn). Yttrium is chosen as the B-site element in order to investigate the role of 4d B-site orbitals on the magnetic character of the system as a whole. Formation energy calculations indicate a transition from XA to L21 dominant phase preference crossing from a V to a Cr A-site element choice, with L21 remaining the dominant phase across the rest of the series. Magnetic data reveal a weak ferrimagnetic yttrium sublattice forming in a similar region of A-site valency as the phase preference transition, indicating a possible structural-magnetic coupling. Total and projected density of states calculations reveal a rich electronic structure with unique hybridization between the A-site and yttrium atoms, particularly for the L21 phase. A near half-metallic gap is found to form in the L21 phase with increasing A-site valency, culminating in a 97.71 % spin polarization for Cr2YSn. Phase stability conclusions are also compared to data from the Open Quantum Materials Database, providing important context for the role of density functional theory (DFT) in informing material synthesis studies. These results provide new insights into the role of element choice in Heusler phase stability and electronic structure, which is critical to identifying novel materials who properties are robust against phase competition.}
}
